{
  "name": "taskflow-pro-server",
  "version": "1.0.0",
  "description": "TaskFlow Pro 企業管理系統 - 離線優先的行動團隊管理平台",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/index.js start",
    "start:simple": "node -e \"require('./dist/server').TaskFlowServer && new (require('./dist/server').TaskFlowServer)({port: process.env.PORT || 3000}).start()\"",
    "init": "node dist/server.js init",
    "backup": "node dist/server.js backup",
    "restore": "node dist/server.js restore",
    "migrate": "node dist/server.js migrate",
    "status": "node dist/server.js status",
    "package": "node build.js",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "keywords": [
    "task-management",
    "offline-first",
    "mobile-team",
    "enterprise",
    "sync",
    "attendance",
    "gps-tracking"
  ],
  "author": "TaskFlow Pro Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "better-sqlite3": "^8.7.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "selfsigned": "^2.4.1",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^9.0.7",
    "@types/multer": "^1.4.11",
    "@types/jest": "^29.5.8",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "pkg": "^5.8.1",
    "rimraf": "^5.0.5",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "data/**/*",
      "uploads/**/*",
      "certificates/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist/executables"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
