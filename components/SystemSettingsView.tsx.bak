
import React, { useState, useEffect, useRef } from 'react';
import { User, DepartmentDef, SystemLog, LogLevel, MenuItemId, DEFAULT_MENU_GROUPS, MENU_LABELS, MenuGroup } from '../types';
import { api } from '../services/api';
import { SOPManagement } from './SOPManagement';
import { useToast } from './Toast';

interface SystemSettingsViewProps {
  currentUser: User;
  onLogout: () => void;
}

export const SystemSettingsView: React.FC<SystemSettingsViewProps> = ({ currentUser, onLogout }) => {
  const toast = useToast();
  const [showConfirmModal, setShowConfirmModal] = useState(false);
  const [confirmInput, setConfirmInput] = useState('');
  const [isResetting, setIsResetting] = useState(false);
  
  // Data for sub-components
  const [departments, setDepartments] = useState<DepartmentDef[]>([]);
  const [logs, setLogs] = useState<SystemLog[]>([]);
  const [logFilter, setLogFilter] = useState<'ALL' | 'DANGER' | 'WARNING'>('ALL');
  
  // Menu Groups State
  const [menuGroups, setMenuGroups] = useState<MenuGroup[]>(DEFAULT_MENU_GROUPS);
  const [isMenuSaving, setIsMenuSaving] = useState(false);

  const fileInputRef = useRef<HTMLInputElement>(null);

  useEffect(() => {
      api.departments.getAll().then(setDepartments);
      api.system.getSettings().then(s => {
          if (s.menuGroups) setMenuGroups(s.menuGroups);
      });
      loadLogs();
  }, []);

  const loadLogs = async () => {
      const data = await api.logs.getAll();
      setLogs(data);
  };

  const CONFIRM_PHRASE = "確認重置系統";

  const handleReset = async () => {
      if (confirmInput !== CONFIRM_PHRASE) {
          toast.error('確認文字輸入錯誤，操作已取消');
          return;
      }

      if (window.confirm("這是最後警告：您即將清除所有資料。此操作無法復原。確定要繼續嗎？")) {
          setIsResetting(true);
          try {
              await api.system.resetFactoryDefault(currentUser);
              toast.success('系統已格式化成功，您將被登出');
              onLogout(); // Force logout to prevent stale data state
          } catch (error) {
              console.error("Reset failed", error);
              toast.error('重置失敗，請聯絡工程師');
          } finally {
              setIsResetting(false);
              setShowConfirmModal(false);
          }
      }
  };

  const handleExport = async () => {
      const data = await api.system.exportData();
      // 確保資料是 JSON 字串格式
      const jsonStr = typeof data === 'string' ? data : JSON.stringify(data, null, 2);
      const blob = new Blob([jsonStr], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      const date = new Date().toISOString().split('T')[0];
      link.download = `taskflow_backup_${date}.json`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
  };

  const handleImportClick = () => {
      fileInputRef.current?.click();
  };

  const handleFileChange = async (e: React.ChangeEvent<HTMLInputElement>) => {
      const file = e.target.files?.[0];
      if (!file) return;

      if (!confirm('您即將匯入資料庫備份，這將會「覆蓋」目前所有的系統資料。\n確定要繼續嗎？')) {
          e.target.value = '';
          return;
      }

      const reader = new FileReader();
      reader.onload = async (event) => {
          try {
              const jsonStr = event.target?.result as string;
              // 驗證 JSON 格式
              JSON.parse(jsonStr);
              const result = await (api as any).system.importData(jsonStr);
              if (result && (result as any).success !== false) {
                  toast.success('資料庫還原成功！系統將重新整理');
                  window.location.reload();
              } else {
                  toast.error('資料庫還原失敗，請檢查檔案格式');
              }
          } catch (error) {
              console.error('匯入錯誤:', error);
              toast.error('資料庫還原失敗：' + (error instanceof Error ? error.message : '未知錯誤'));
          }
      };
      reader.readAsText(file);
      e.target.value = '';
  };

  // --- Menu Group Reordering Logic ---
  const moveGroup = (index: number, direction: 'up' | 'down') => {
      const newGroups = [...menuGroups];
      if (direction === 'up' && index > 0) {
          [newGroups[index], newGroups[index - 1]] = [newGroups[index - 1], newGroups[index]];
      } else if (direction === 'down' && index < menuGroups.length - 1) {
          [newGroups[index], newGroups[index + 1]] = [newGroups[index + 1], newGroups[index]];
      }
      setMenuGroups(newGroups);
  };

  // --- Menu Item Reordering Logic (Within Group) ---
  const moveItemInGroup = (groupIndex: number, itemIndex: number, direction: 'up' | 'down') => {
      const newGroups = [...menuGroups];
      const items = [...newGroups[groupIndex].items];
      
      if (direction === 'up' && itemIndex > 0) {
          [items[itemIndex], items[itemIndex - 1]] = [items[itemIndex - 1], items[itemIndex]];
      } else if (direction === 'down' && itemIndex < items.length - 1) {
          [items[itemIndex], items[itemIndex + 1]] = [items[itemIndex + 1], items[itemIndex]];
      }
      
      newGroups[groupIndex] = { ...newGroups[groupIndex], items };
      setMenuGroups(newGroups);
  };

  const handleSaveMenuOrder = async () => {
      setIsMenuSaving(true);
      // Fixed error: Expected 1 argument, but got 2. The second argument 'currentUser' was removed to match api.system.saveSettings' defined signature.
      await api.system.saveSettings({ menuGroups });
      setIsMenuSaving(false);
      toast.success('選單排序已儲存，請重新整理頁面');
  };

  const getLogLevelStyle = (level: LogLevel) => {
      switch(level) {
          case 'DANGER': return 'bg-red-100 text-red-700 border-red-200';
          case 'WARNING': return 'bg-amber-100 text-amber-700 border-amber-200';
          default: return 'bg-slate-100 text-slate-600 border-slate-200';
      }
  };

  // Improved Action Badges
  const getActionBadge = (action: string) => {
      if (action.includes('CREATE')) return 'bg-emerald-100 text-emerald-700 border-emerald-200';
      if (action.includes('DELETE')) return 'bg-red-100 text-red-700 border-red-200';
      if (action.includes('UPDATE')) return 'bg-blue-100 text-blue-700 border-blue-200';
      if (action.includes('RESET')) return 'bg-slate-800 text-white border-slate-900';
      return 'bg-slate-50 text-slate-600 border-slate-200';
  };

  const filteredLogs = logs.filter(log => {
      if (logFilter === 'ALL') return true;
      return log.level === logFilter;
  });

  return (
    <div className="max-w-4xl mx-auto space-y-8 animate-fade-in pb-20">
       
       <div className="flex flex-col md:flex-row justify-between items-end gap-4 border-b border-slate-200 pb-4">
          <div>
            <h2 className="text-2xl font-black text-slate-800 tracking-tight flex items-center gap-2">
               <span>⚙️</span> 系統設定
            </h2>
            <p className="text-sm text-slate-500 font-bold mt-1">系統環境配置與資料管理</p>
          </div>
       </div>

       {/* Menu Order Settings (Grouped) */}
       <div className="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
           <div className="flex justify-between items-center mb-4">
                <h3 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                    <span>📑</span> 選單導航排序 (分組模式)
                </h3>
                <button 
                    onClick={handleSaveMenuOrder}
                    disabled={isMenuSaving}
                    className="bg-slate-800 text-white px-4 py-2 rounded-lg font-bold text-sm hover:bg-slate-700 transition"
                >
                    {isMenuSaving ? '儲存中...' : '儲存排序'}
                </button>
           </div>
           <p className="text-sm text-slate-500 mb-4">
               您可以調整功能群組的順序，以及群組內的項目排序。
           </p>
           
           <div className="space-y-4">
               {menuGroups.map((group, gIndex) => (
                   <div key={group.id} className="bg-slate-50 border border-slate-200 rounded-xl overflow-hidden">
                       {/* Group Header */}
                       <div className="bg-slate-100 p-3 flex justify-between items-center border-b border-slate-200">
                           <div className="flex items-center gap-2">
                               <div className="flex flex-col gap-0.5">
                                   <button 
                                     onClick={() => moveGroup(gIndex, 'up')}
                                     disabled={gIndex === 0}
                                     className="w-5 h-5 flex items-center justify-center bg-white hover:bg-blue-50 rounded text-slate-600 border border-slate-200 disabled:opacity-30"
                                   >
                                       ▲
                                   </button>
                                   <button 
                                     onClick={() => moveGroup(gIndex, 'down')}
                                     disabled={gIndex === menuGroups.length - 1}
                                     className="w-5 h-5 flex items-center justify-center bg-white hover:bg-blue-50 rounded text-slate-600 border border-slate-200 disabled:opacity-30"
                                   >
                                       ▼
                                   </button>
                               </div>
                               <span className="font-black text-slate-700 ml-2">{group.label}</span>
                           </div>
                       </div>

                       {/* Group Items */}
                       <div className="p-2 space-y-2">
                           {group.items.map((itemId, iIndex) => {
                               const item = MENU_LABELS[itemId];
                               if (!item) return null;
                               return (
                                   <div key={itemId} className="flex items-center gap-3 bg-white p-2 rounded-lg border border-slate-200 shadow-sm ml-8">
                                       <div className="flex gap-1">
                                           <button 
                                             onClick={() => moveItemInGroup(gIndex, iIndex, 'up')}
                                             disabled={iIndex === 0}
                                             className="w-6 h-6 flex items-center justify-center bg-slate-50 hover:bg-slate-100 rounded text-slate-400 disabled:opacity-30 text-xs"
                                           >
                                               ↑
                                           </button>
                                           <button 
                                             onClick={() => moveItemInGroup(gIndex, iIndex, 'down')}
                                             disabled={iIndex === group.items.length - 1}
                                             className="w-6 h-6 flex items-center justify-center bg-slate-50 hover:bg-slate-100 rounded text-slate-400 disabled:opacity-30 text-xs"
                                           >
                                               ↓
                                           </button>
                                       </div>
                                       <span className="text-lg">{item.icon}</span>
                                       <span className="font-bold text-slate-600 text-sm">{item.label}</span>
                                   </div>
                               );
                           })}
                           {group.items.length === 0 && (
                               <div className="text-center text-xs text-slate-400 py-2 italic">無項目</div>
                           )}
                       </div>
                   </div>
               ))}
           </div>
       </div>

       {/* SOP Management Section */}
       <div className="space-y-4">
           <SOPManagement departments={departments} currentUser={currentUser} />
       </div>

       {/* Database Backup & Restore */}
       <div className="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
           <h3 className="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
               <span>💾</span> 資料庫備份與還原
           </h3>
           <p className="text-sm text-slate-500 mb-6">
               由於本系統目前運行於本地環境，建議定期手動備份資料，以免清除瀏覽器快取造成資料遺失。
           </p>
           
           <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
               <div className="p-4 bg-slate-50 rounded-xl border border-slate-200 flex flex-col items-start gap-3">
                   <h4 className="font-bold text-slate-700">匯出資料備份 (Backup)</h4>
                   <p className="text-xs text-slate-400">下載完整的 JSON 資料庫檔案到您的電腦。</p>
                   <button 
                     onClick={handleExport}
                     className="bg-slate-800 text-white px-4 py-2 rounded-lg font-bold text-sm hover:bg-slate-700 transition flex items-center gap-2"
                   >
                       <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                       下載備份檔
                   </button>
               </div>

               <div className="p-4 bg-blue-50 rounded-xl border border-blue-100 flex flex-col items-start gap-3">
                   <h4 className="font-bold text-blue-800">還原資料庫 (Restore)</h4>
                   <p className="text-xs text-blue-600">上傳備份檔以覆蓋當前資料 (請謹慎使用)。</p>
                   <button 
                     onClick={handleImportClick}
                     className="bg-blue-600 text-white px-4 py-2 rounded-lg font-bold text-sm hover:bg-blue-700 transition flex items-center gap-2"
                   >
                       <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                       上傳還原
                   </button>
                   <input type="file" accept=".json" ref={fileInputRef} className="hidden" onChange={handleFileChange} />
               </div>
           </div>
       </div>

       {/* Audit Log Viewer */}
       <div className="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
           <div className="flex justify-between items-center mb-6">
                <h3 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                    <span>👮‍♂️</span> 系統操作審計日誌 (Audit Logs)
                </h3>
                <div className="flex bg-slate-100 p-1 rounded-lg">
                    <button onClick={() => setLogFilter('ALL')} className={`px-3 py-1 rounded text-xs font-bold transition ${logFilter === 'ALL' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500'}`}>全部</button>
                    <button onClick={() => setLogFilter('WARNING')} className={`px-3 py-1 rounded text-xs font-bold transition ${logFilter === 'WARNING' ? 'bg-white shadow-sm text-amber-600' : 'text-slate-500'}`}>警告</button>
                    <button onClick={() => setLogFilter('DANGER')} className={`px-3 py-1 rounded text-xs font-bold transition ${logFilter === 'DANGER' ? 'bg-white shadow-sm text-red-600' : 'text-slate-500'}`}>危險</button>
                </div>
           </div>

           <div className="overflow-x-auto max-h-[500px] border border-slate-200 rounded-lg">
               <table className="w-full text-left border-collapse relative">
                   <thead className="sticky top-0 z-10">
                       <tr className="bg-slate-100 text-xs text-slate-600 uppercase font-black border-b border-slate-200">
                           <th className="p-3">時間</th>
                           <th className="p-3">等級</th>
                           <th className="p-3">操作人員</th>
                           <th className="p-3">動作類型</th>
                           <th className="p-3">詳細內容</th>
                       </tr>
                   </thead>
                   <tbody className="text-sm divide-y divide-slate-100 bg-white">
                       {filteredLogs.length === 0 ? (
                           <tr><td colSpan={5} className="p-6 text-center text-slate-400 italic">無相關日誌紀錄</td></tr>
                       ) : (
                           filteredLogs.map(log => (
                               <tr key={log.id} className="hover:bg-slate-50 transition">
                                   <td className="p-3 font-mono text-xs text-slate-500 whitespace-nowrap">
                                       {new Date(log.timestamp).toLocaleString()}
                                   </td>
                                   <td className="p-3">
                                       <span className={`px-2 py-0.5 rounded text-[10px] font-bold border ${getLogLevelStyle(log.level)}`}>
                                           {log.level}
                                       </span>
                                   </td>
                                   <td className="p-3 font-bold text-slate-700 whitespace-nowrap">
                                       {log.userName}
                                   </td>
                                   <td className="p-3">
                                       <span className={`text-[10px] font-bold px-2 py-1 rounded border ${getActionBadge(log.action)}`}>
                                           {log.action}
                                       </span>
                                   </td>
                                   <td className="p-3 text-slate-600 break-all">
                                       {log.details}
                                   </td>
                               </tr>
                           ))
                       )}
                   </tbody>
               </table>
           </div>
           <p className="text-xs text-slate-400 mt-4 text-right">
               * 僅顯示最近 200 筆操作紀錄
           </p>
       </div>

       {/* Danger Zone */}
       <div className="bg-red-50 rounded-xl border border-red-200 p-6 shadow-sm relative overflow-hidden">
           <div className="absolute -right-10 -top-10 text-9xl text-red-100 opacity-50 rotate-12 select-none">⚠️</div>
           
           <h3 className="text-xl font-black text-red-700 mb-2 relative z-10 flex items-center gap-2">
               <span>☢️</span> 危險操作區 (Danger Zone)
           </h3>
           <p className="text-sm text-red-600 mb-6 relative z-10 font-medium">
               以下操作將會對系統造成不可逆的影響，請謹慎使用。
           </p>

           <div className="bg-white/80 backdrop-blur-sm rounded-lg border border-red-200 p-4 flex flex-col md:flex-row justify-between items-center gap-4 relative z-10">
               <div>
                   <h4 className="font-bold text-slate-800">格式化系統資料庫 (Factory Reset)</h4>
                   <p className="text-xs text-slate-500 mt-1">
                       清除所有任務、公告、報表、財務與通訊紀錄。<br/>
                       僅保留預設部門與預設管理員帳號 (Boss)。
                   </p>
               </div>
               <button 
                  onClick={() => setShowConfirmModal(true)}
                  className="bg-red-600 hover:bg-red-700 text-white px-6 py-2.5 rounded-lg font-bold shadow-lg shadow-red-200 transition transform hover:-translate-y-0.5 whitespace-nowrap"
               >
                   格式化系統
               </button>
           </div>
       </div>

       {/* Confirmation Modal */}
       {showConfirmModal && (
           <div className="fixed inset-0 z-[100] flex items-center justify-center bg-slate-900/80 backdrop-blur-sm p-4 animate-shake">
               <div className="bg-white rounded-xl shadow-2xl w-full max-w-md border-t-4 border-red-500 overflow-hidden">
                   <div className="p-6">
                       <h3 className="text-xl font-black text-red-600 mb-4 flex items-center gap-2">
                           <span>⚠️</span> 警告：極度危險
                       </h3>
                       <p className="text-slate-700 text-sm leading-relaxed mb-4 font-bold">
                           您即將刪除整個組織的所有業務資料！<br/>
                           此操作 <span className="text-red-600 underline">無法復原</span>，所有員工的任務與紀錄將會消失。
                       </p>
                       <p className="text-slate-500 text-xs mb-2">
                           請在下方輸入 "<span className="font-mono font-bold text-slate-800 select-all">{CONFIRM_PHRASE}</span>" 以確認執行：
                       </p>
                       <input 
                         type="text" 
                         value={confirmInput}
                         onChange={(e) => setConfirmInput(e.target.value)}
                         className="w-full border-2 border-red-200 rounded-lg px-4 py-2 font-bold text-red-700 focus:ring-2 focus:ring-red-500 outline-none text-center"
                         placeholder="輸入確認文字"
                         autoFocus
                       />
                   </div>
                   <div className="bg-slate-50 p-4 flex justify-end gap-3 border-t border-slate-100">
                       <button 
                         onClick={() => { setShowConfirmModal(false); setConfirmInput(''); }}
                         className="px-4 py-2 text-slate-600 font-bold hover:bg-slate-200 rounded-lg transition"
                       >
                           取消
                       </button>
                       <button 
                         onClick={handleReset}
                         disabled={confirmInput !== CONFIRM_PHRASE || isResetting}
                         className="px-6 py-2 bg-red-600 text-white font-bold rounded-lg hover:bg-blue-700 shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
                       >
                           {isResetting ? '正在毀滅資料...' : '確認刪除'}
                       </button>
                   </div>
               </div>
           </div>
       )}
    </div>
  );
};
