# 資料庫配置
DB_PASSWORD=your_secure_database_password_here

# JWT 認證密鑰
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# 伺服器配置
NODE_ENV=production
PORT=5000

# 檔案上傳配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 前端配置（Netlify 部署時使用）
VITE_API_URL=https://taskflow-pro-server-production.up.railway.app/api

# Gemini API Key（如需使用 AI 功能）
GEMINI_API_KEY=your_gemini_api_key_here
