{
  "name": "taskflow-pro-server",
  "version": "1.0.0",
  "description": "TaskFlow Pro 企業管理系統 - 可攜式伺服器",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "package": "pkg dist/server.js --targets node18-win-x64,node18-linux-x64 --output ./dist/TaskFlowProServer",
    "package-win": "pkg dist/server.js --targets node18-win-x64 --output ./dist/TaskFlowProServer.exe",
    "package-linux": "pkg dist/server.js --targets node18-linux-x64 --output ./dist/TaskFlowProServer-linux",
    "start": "node dist/server.js",
    "init-db": "ts-node src/scripts/init-database.ts",
    "backup": "ts-node src/scripts/backup.ts",
    "restore": "ts-node src/scripts/restore.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "sqlcipher": "^5.1.1",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "archiver": "^6.0.1",
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/archiver": "^6.0.2",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "dist/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  }
}
