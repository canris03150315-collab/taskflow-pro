FROM node:20-alpine

RUN apk add --no-cache python3 make g++

WORKDIR /app

COPY server/package*.json ./

RUN npm install

COPY server/ ./

RUN npx tsc --noEmitOnError false || npx tsc || echo "Build completed with errors"

RUN ls -la dist/ && test -f dist/index.js || (echo "ERROR: dist/index.js not found!" && exit 1)

RUN mkdir -p /app/data /app/data/uploads /app/data/backups /app/data/certificates /app/data/logs

EXPOSE 3000

CMD ["node", "dist/index.js", "start"]
