        },
        markRead: async (id: string, userId: string): Promise<void> => {
            await delay();
            const ann = MOCK_DB.announcements.find(a => a.id === id);
            if (ann && !ann.readBy.includes(userId)) {
                ann.readBy.push(userId);
                saveToStorage();
